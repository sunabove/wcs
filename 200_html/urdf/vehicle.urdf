<?xml version="1.0"?>
<robot name="realistic_vehicle">

    <!-- ================================================= -->
    <!-- MATERIALS -->
    <!-- ================================================= -->

    <material name="body_main">
        <color rgba="0.38 0.40 0.44 1.0"/>
    </material>

    <material name="body_trim">
        <color rgba="0.18 0.20 0.24 1.0"/>
    </material>

    <material name="tire">
        <color rgba="0.04 0.04 0.04 1.0"/>
    </material>

    <material name="rim">
        <color rgba="0.82 0.82 0.84 1.0"/>
    </material>

    <!-- Front light -->
    <material name="front_light">
        <color rgba="1.0 1.0 0.85 1.0"/>
    </material>

    <!-- Rear light -->
    <material name="rear_light">
        <color rgba="1.0 0.1 0.1 1.0"/>
    </material>

    <!-- ================================================= -->
    <!-- BASE LINK -->
    <!-- ================================================= -->

    <link name="base_link">

        <!-- Main lower chassis -->
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="1.05 0.62 0.10"/>
            </geometry>
            <material name="body_trim"/>
        </visual>

        <!-- Main upper body -->
        <visual>
            <origin xyz="-0.05 0 0.11" rpy="0 0 0"/>
            <geometry>
                <box size="0.78 0.48 0.08"/>
            </geometry>
            <material name="body_main"/>
        </visual>

        <!-- Front hood (longer) -->
        <visual>
            <origin xyz="0.38 0 0.12" rpy="0 -0.18 0"/>
            <geometry>
                <box size="0.34 0.48 0.04"/>
            </geometry>
            <material name="body_main"/>
        </visual>

        <!-- Rear trunk (shorter) -->
        <visual>
            <origin xyz="-0.40 0 0.12" rpy="0 0.04 0"/>
            <geometry>
                <box size="0.18 0.46 0.04"/>
            </geometry>
            <material name="body_main"/>
        </visual>

        <!-- Front bumper -->
        <visual>
            <origin xyz="0.54 0 0.04" rpy="0 0 0"/>
            <geometry>
                <box size="0.04 0.60 0.06"/>
            </geometry>
            <material name="body_trim"/>
        </visual>

        <!-- Rear bumper -->
        <visual>
            <origin xyz="-0.54 0 0.04" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.56 0.05"/>
            </geometry>
            <material name="body_trim"/>
        </visual>

        <!-- ================================================= -->
        <!-- FRONT LIGHTS -->
        <!-- ================================================= -->

        <visual>
            <origin xyz="0.54 0.20 0.10" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.10 0.03"/>
            </geometry>
            <material name="front_light"/>
        </visual>

        <visual>
            <origin xyz="0.54 -0.20 0.10" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.10 0.03"/>
            </geometry>
            <material name="front_light"/>
        </visual>

        <!-- ================================================= -->
        <!-- REAR LIGHTS -->
        <!-- ================================================= -->

        <visual>
            <origin xyz="-0.54 0.18 0.09" rpy="0 0 0"/>
            <geometry>
                <box size="0.012 0.08 0.025"/>
            </geometry>
            <material name="rear_light"/>
        </visual>

        <visual>
            <origin xyz="-0.54 -0.18 0.09" rpy="0 0 0"/>
            <geometry>
                <box size="0.012 0.08 0.025"/>
            </geometry>
            <material name="rear_light"/>
        </visual>

        <!-- Front grill -->
        <visual>
            <origin xyz="0.525 0 0.09" rpy="0 0 0"/>
            <geometry>
                <box size="0.01 0.22 0.04"/>
            </geometry>
            <material name="body_trim"/>
        </visual>

        <!-- Rear plate area -->
        <visual>
            <origin xyz="-0.545 0 0.09" rpy="0 0 0"/>
            <geometry>
                <box size="0.005 0.18 0.04"/>
            </geometry>
            <material name="rim"/>
        </visual>

        <!-- Collision -->
        <collision>
            <origin xyz="0 0 0.09"/>
            <geometry>
                <box size="1.08 0.62 0.18"/>
            </geometry>
        </collision>


        <!-- ================================================= -->
        <!-- WHEEL AXLES -->
        <!-- ================================================= -->

        <!-- Front left axle -->
        <visual>
            <origin xyz="0.34 0.305 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.21"/>
            </geometry>
            <material name="rim"/>
        </visual>

        <!-- Front right axle -->
        <visual>
            <origin xyz="0.34 -0.305 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.21"/>
            </geometry>
            <material name="rim"/>
        </visual>

        <!-- Rear left axle -->
        <visual>
            <origin xyz="-0.34 0.305 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.21"/>
            </geometry>
            <material name="rim"/>
        </visual>

        <!-- Rear right axle -->
        <visual>
            <origin xyz="-0.34 -0.305 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.025" length="0.21"/>
            </geometry>
            <material name="rim"/>
        </visual>

        <!-- Inertia -->
        <inertial>
            <mass value="38"/>
            <origin xyz="0 0 0.09"/>
            <inertia
                ixx="2.5"
                ixy="0.0"
                ixz="0.0"
                iyy="2.5"
                iyz="0.0"
                izz="2.5"/>
        </inertial>

    </link>

    <!-- ================================================= -->
    <!-- FRONT LEFT WHEEL -->
    <!-- ================================================= -->

    <link name="wheel_fl">

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.15" length="0.11"/>
            </geometry>
            <material name="tire"/>
        </visual>

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.085" length="0.12"/>
            </geometry>
            <material name="rim"/>
        </visual>

    </link>

    <joint name="joint_fl" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_fl"/>
        <origin xyz="0.34 0.41 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- ================================================= -->
    <!-- FRONT RIGHT WHEEL -->
    <!-- ================================================= -->

    <link name="wheel_fr">

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.15" length="0.11"/>
            </geometry>
            <material name="tire"/>
        </visual>

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.085" length="0.12"/>
            </geometry>
            <material name="rim"/>
        </visual>

    </link>

    <joint name="joint_fr" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_fr"/>
        <origin xyz="0.34 -0.41 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- ================================================= -->
    <!-- REAR LEFT WHEEL -->
    <!-- ================================================= -->

    <link name="wheel_rl">

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.15" length="0.11"/>
            </geometry>
            <material name="tire"/>
        </visual>

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.085" length="0.12"/>
            </geometry>
            <material name="rim"/>
        </visual>

    </link>

    <joint name="joint_rl" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rl"/>
        <origin xyz="-0.34 0.41 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- ================================================= -->
    <!-- REAR RIGHT WHEEL -->
    <!-- ================================================= -->

    <link name="wheel_rr">

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.15" length="0.11"/>
            </geometry>
            <material name="tire"/>
        </visual>

        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder radius="0.085" length="0.12"/>
            </geometry>
            <material name="rim"/>
        </visual>

    </link>

    <joint name="joint_rr" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_rr"/>
        <origin xyz="-0.34 -0.41 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

</robot>